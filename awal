#!/usr/bin/env python3
import os
import subprocess
import sys

EXT_IMAGENES = {".png", ".jpg", ".jpeg"}
EXT_VIDEOS = {".mp4", ".mkv", ".webm"}


def main():
    if len(sys.argv) < 3:
        print("Uso: awal [-i imagen | -v video] ruta")
        sys.exit(1)

    modo = sys.argv[1]
    ruta_wallpaper = os.path.expanduser(sys.argv[2])

    if not os.path.isfile(ruta_wallpaper):
        print(f"Error: el archivo '{ruta_wallpaper}' no existe")
        sys.exit(1)

    _, ext = os.path.splitext(ruta_wallpaper.lower())
    if modo == "-i" and ext not in EXT_IMAGENES:
        print(f"Error: extensión inválida para imagen: {ext}")
        sys.exit(1)
    if modo == "-v" and ext not in EXT_VIDEOS:
        print(f"Error: extensión inválida para video: {ext}")
        sys.exit(1)

    ruta_frame = os.path.expanduser("~/.cache/wal/animated/frame.png")
    os.makedirs(os.path.dirname(ruta_frame), exist_ok=True)

    if modo == "-i":
        subprocess.run(
            ["pkill", "mpvpaper"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        subprocess.run(["wal", "-i", ruta_wallpaper])

    elif modo == "-v":
        subprocess.run(
            [
                "ffmpeg",
                "-y",
                "-i",
                ruta_wallpaper,
                "-vf",
                r"select=eq(n\,0)",
                "-vframes",
                "1",
                "-update",
                "1",
                ruta_frame,
            ],
            check=True,
        )
        subprocess.run(["wal", "-i", ruta_frame])
        subprocess.run(
            ["pkill", "mpvpaper"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL
        )
        subprocess.Popen(
            ["mpvpaper", "-o", "loop", "*", ruta_wallpaper],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    else:
        print("Error: argumento inválido [-i imagen | -v video]")
        sys.exit(1)


if __name__ == "__main__":
    main()
